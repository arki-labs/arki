{
  "extends": "@arki/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "types": ["node"],
    "tsBuildInfoFile": "./.cache/tsbuildinfo.json"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
